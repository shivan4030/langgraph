+class _RestrictedUnpickler(pickle.Unpickler):
+    def __init__(
+        self,
+        file: io.BufferedReader | io.BytesIO,
+        *,
+        allowed_modules: Iterable[tuple[str, ...]] | Literal[True] | None,
+        **kwargs: Any,
+    ) -> None:
+        super().__init__(file, **kwargs)
+        self.allowed_modules = allowed_modules
+        if self.allowed_modules is True:
+            warnings.warn(
+                "Unpickling is unrestricted. This is unsafe if the data comes from an "
+                "untrusted source. Consider explicitly setting `allowed_pickle_modules` "
+                "on JsonPlusSerializer.",
+                UserWarning,
+                stacklevel=3,
+            )
+
+    def find_class(self, module: str, name: str) -> Any:
+        if self.allowed_modules is True:
+            return super().find_class(module, name)
+        if self.allowed_modules is not None:
+            parts = tuple(module.split("."))
+            for m in self.allowed_modules:
+                if parts[: len(m)] == m:
+                    return super().find_class(module, name)
+        raise pickle.UnpicklingError(
+            f"Global '{module}.{name}' is forbidden by restricted unpickler."
+        )

